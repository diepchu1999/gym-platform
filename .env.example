# Sao chép thành .env rồi chỉnh nếu cần. Dùng cho docker-compose VÀ app (giá trị phải khớp nhau).

# ----- PostgreSQL -----
POSTGRES_DB=gym_platform
POSTGRES_USER=gym
POSTGRES_PASSWORD=gym_dev_password
POSTGRES_PORT=5432

# ----- App datasource (Spring) -----
DB_URL=jdbc:postgresql://localhost:5432/gym_platform
DB_USERNAME=gym
DB_PASSWORD=gym_dev_password
SERVER_PORT=8080

# ----- pgAdmin -----
PGADMIN_DEFAULT_EMAIL=admin@gym-platform.com
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=5050

# ----- Keycloak (authentication) -----
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_PORT=8085

# ----- Redis (cache + short locks) -----
REDIS_PORT=6379

# ----- MinIO (S3 object storage) -----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ----- Observability -----
PROMETHEUS_PORT=9090
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_PORT=3000
ZIPKIN_PORT=9411
ZIPKIN_ENDPOINT=http://localhost:9411/api/v2/spans
TRACING_SAMPLE=1.0
