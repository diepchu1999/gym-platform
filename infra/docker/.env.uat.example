# ============================================================
# gym-platform UAT environment template
# Copy this file to infra/docker/.env.uat on the VM and fill real values.
# DO NOT commit infra/docker/.env.uat.
# ============================================================

# ----------------------------
# Container image
# ----------------------------
# GitHub Container Registry owner/org/user.
# Example: diepchu
GHCR_OWNER=your-github-owner

# Immutable tag preferred: git sha or release tag.
# For manual build on VM, "uat" is fine.
APP_TAG=uat

# JVM options for app container.
APP_JAVA_OPTS=-XX:MaxRAMPercentage=65.0 -XX:+ExitOnOutOfMemoryError


# ----------------------------
# Spring Boot app
# ----------------------------
SERVER_PORT=8080

# App database. The compose file uses internal DNS postgres:5432.
POSTGRES_DB=gym_platform
POSTGRES_USER=gym
POSTGRES_PASSWORD=change-me-strong-db-password

# Public issuer URL MUST match Keycloak token "iss" claim.
# Replace this after Cloudflare Tunnel is ready.
# Example: https://kc-gym-platform.example.com/realms/gym-platform
KEYCLOAK_ISSUER_URI=https://replace-with-keycloak-public-host/realms/gym-platform

# App uses internal network for JWKS. Usually do not change this in compose.
KEYCLOAK_JWK_SET_URI=http://keycloak:8080/realms/gym-platform/protocol/openid-connect/certs

TRACING_SAMPLE=0.0
ZIPKIN_ENDPOINT=http://zipkin:9411/api/v2/spans


# ----------------------------
# Keycloak
# ----------------------------
# Bootstrap admin for Keycloak admin console.
# Used only on first boot when Keycloak DB is empty.
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-strong-keycloak-admin-password

# Keycloak DB is separate from app DB but hosted by the same Postgres container.
KEYCLOAK_DB=keycloak

# Public Keycloak hostname behind Cloudflare Tunnel.
# Must NOT include path /realms/...
# Example: https://kc-gym-platform.example.com
KC_HOSTNAME=https://replace-with-keycloak-public-host

# Keycloak realm import contains DEV-only superadmin user.
# First login may require password update if temporary credential is enabled.
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_INITIAL_PASSWORD=ChangeMe123!


# ----------------------------
# Optional profiles: object storage
# ----------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password


# ----------------------------
# Optional profiles: observability/tools
# ----------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password

PGADMIN_DEFAULT_EMAIL=admin@gym-platform.com
PGADMIN_DEFAULT_PASSWORD=change-me-pgadmin-password